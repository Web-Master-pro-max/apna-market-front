{
  "version": 2,
  "builds": [
    { "src": "*.html", "use": "@vercel/static" },
    { "src": "*.css", "use": "@vercel/static" },
    { "src": "*.js", "use": "@vercel/static" },
    { "src": "img/**/*", "use": "@vercel/static" },
    { "src": "images/**/*", "use": "@vercel/static" }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "http://13.62.153.215:5000/api/$1",
      "headers": {
        "Access-Control-Allow-Origin": "*",
        "Access-Control-Allow-Methods": "GET, POST, PUT, DELETE, OPTIONS",
        "Access-Control-Allow-Headers": "Content-Type, Authorization, X-Requested-With",
        "Access-Control-Allow-Credentials": "true"
      }
    },
    {
      "src": "/uploads/(.*)",
      "dest": "http://13.62.153.215:5000/uploads/$1"
    },
    {
      "src": "/socket.io/(.*)",
      "dest": "http://13.62.153.215:5000/socket.io/$1"
    },
    {
      "src": "/(.*)\\.(css|js|png|jpg|jpeg|svg|ico|json|map|webp|avif|gif|ttf|woff2?|eot)",
      "dest": "/$1.$2"
    },
    {
      "src": "/products",
      "dest": "/products.html"
    },
    {
      "src": "/product",
      "dest": "/product.html"
    },
    {
      "src": "/cart",
      "dest": "/cart.html"
    },
    {
      "src": "/checkout",
      "dest": "/checkout.html"
    },
    {
      "src": "/orders",
      "dest": "/orders.html"
    },
    {
      "src": "/order-confirmation",
      "dest": "/order-confirmation.html"
    },
    {
      "src": "/login",
      "dest": "/login.html"
    },
    {
      "src": "/register",
      "dest": "/login.html"
    },
    {
      "src": "/profile",
      "dest": "/profile.html"
    },
    {
      "src": "/seller",
      "dest": "/seller.html"
    },
    {
      "src": "/sell",
      "dest": "/sell.html"
    },
    {
      "src": "/admin",
      "dest": "/admin.html"
    },
    {
      "src": "/live",
      "dest": "/live.html"
    },
    {
      "src": "/chats",
      "dest": "/chat-list.html"
    },
    {
      "src": "/chat",
      "dest": "/chat.html"
    },
    {
      "src": "/",
      "dest": "/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "/$1.html"
    }
  ]
}